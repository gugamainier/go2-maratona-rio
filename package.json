{
  "name": "transport-tracker",
  "version": "1.0.0",
  "description": "Sistema de rastreamento de transporte executivo - Rio de Janeiro",
  "main": "server/index.js",
  "scripts": {
    "start": "node --experimental-sqlite server/index.js",
    "dev": "nodemon --experimental-sqlite server/index.js",
    "seed": "node --experimental-sqlite server/seed.js",
    "setup": "npm install && cd client/panel && npm install",
    "build": "cd client/panel && npm run build"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "connect-sqlite3": "^0.9.16",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "qrcode": "^1.5.3",
    "socket.io": "^4.6.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
