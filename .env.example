# Porta do servidor (Railway define automaticamente)
PORT=3000

# Segredo da sessão — MUDE para uma string aleatória longa em produção
SESSION_SECRET=go2-maratona-rio-secret-MUDE-ISSO

# Tempo offline (ms) para marcar motorista como offline
OFFLINE_THRESHOLD_MS=15000

# Distância (m) para alertar saída de rota
OFF_ROUTE_THRESHOLD_M=200

# Ambiente (production | development)
NODE_ENV=production
